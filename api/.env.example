# ===========================================
# Crebortoli API - Configuração de Ambiente
# ===========================================

# Credenciais de produção - NÃO COMMITAR
# Execute: node scripts/encrypt.js encrypt <sua-senha> .env
CREBORTOLI_DB_HOST=127.0.0.1
CREBORTOLI_DB_PORT=5432
CREBORTOLI_DB_USER=postgres
CREBORTOLI_DB_PASS=senha_forte_aqui
CREBORTOLI_DB_NAME=crebortoli

# Autenticação API (OBRIGATÓRIO)
API_TOKEN=gerar_token_seguro_aqui

# CORS - Liste os domínios permitidos separados por vírgula
# Exemplos:
# ALLOWED_ORIGINS=https://crebortoli.com.br,https://www.crebortoli.com.br
ALLOWED_ORIGINS=

# Upload de arquivos (opcional)
UPLOAD_DIR=uploads

# ===========================================
# ENCRIPTAÇÃO (OBRIGATÓRIO em produção)
# ===========================================
# Senha para descriptografar .env - NÃO COMMITAR
# Gere com: node scripts/encrypt.js encrypt <senha> .env
# Execute o script na pasta api/
# Depois delete o .env original e keep apenas .env.enc
ENV_PASSWORD=sua-senha-aqui